<!DOCTYPE html>
<html lang="ckb" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Garmyan Style | Premium Studio</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Vazirmatn:wght@300;500;700;900&display=swap');
        body { 
            font-family: 'Vazirmatn', sans-serif;
            background: radial-gradient(circle at 50% 0%, #1a103c 0%, #07080a 100%);
        }
        /* کاریگەری درەوشانەوەی نیۆن بۆ سەرنجڕاکێشی زێدە */
        .neon-glow {
            box-shadow: 0 0 35px -5px rgba(139, 92, 246, 0.2);
        }
        .neon-card {
            background: rgba(15, 17, 23, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
    </style>
</head>
<body class="text-gray-100 min-h-screen flex flex-col justify-between">

    <header class="p-6 max-w-5xl w-full mx-auto flex justify-between items-center border-b border-white/5">
        <div class="flex items-center gap-3">
            <div class="w-3 h-3 rounded-full bg-violet-500 animate-ping"></div>
            <h1 class="text-2xl font-black tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-fuchsia-400 uppercase">
                GARMYAN STYLE
            </h1>
        </div>
        <button onclick="openAdminModal()" class="text-xs font-medium bg-white/5 hover:bg-violet-600 hover:text-white px-4 py-2 rounded-full border border-white/10 transition-all duration-300">
            کۆنترۆڵی ئەدمین
        </button>
    </header>

    <main class="max-w-4xl w-full mx-auto p-4 sm:p-6 flex-grow flex flex-col justify-center">
        
        <div class="neon-card p-6 rounded-3xl text-center mb-8 border border-violet-500/10 neon-glow relative overflow-hidden">
            <div class="absolute -top-10 -left-10 w-32 h-32 bg-violet-600/10 rounded-full blur-3xl"></div>
            <p class="text-xs text-violet-400 font-bold tracking-widest uppercase mb-1">PREMIUM BARBER STUDIO</p>
            <p class="text-sm text-gray-400 font-light">📍 قەزای ڕزگاری - بەرامبەر قوتابخانەی کۆمار</p>
            <p class="text-xs text-gray-500 mt-2">🕒 کاتی ئیشکردن: ٤:٠٠ی عەسڕ بۆ ١٢:٠٠ی شەو</p>
        </div>

        <section class="neon-card p-6 sm:p-8 rounded-3xl mb-8">
            <h2 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
                <span class="w-1 h-4 bg-gradient-to-b from-violet-500 to-fuchsia-500 rounded-full"></span>
                زانیارییەکانت بنووسە
            </h2>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                    <label class="block text-xs text-gray-400 mb-2 font-medium">ناوی تەواو</label>
                    <input type="text" id="customerName" placeholder="ناو لێرە بنووسە..." class="w-full bg-black/40 border border-white/10 rounded-xl p-3.5 text-white text-sm focus:outline-none focus:border-violet-500 transition-all">
                </div>
                <div>
                    <label class="block text-xs text-gray-400 mb-2 font-medium">ژمارەی مۆبایل</label>
                    <input type="tel" id="customerPhone" placeholder="0750XXXXXXX" class="w-full bg-black/40 border border-white/10 rounded-xl p-3.5 text-white text-sm text-left focus:outline-none focus:border-violet-500 transition-all" dir="ltr">
                </div>
            </div>
        </section>

        <section class="mb-12">
            <h2 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
                <span class="w-1 h-4 bg-gradient-to-b from-violet-500 to-fuchsia-500 rounded-full"></span>
                خشتەی کاتەکانی ئەمرۆ
            </h2>
            <div id="slotsContainer" class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                </div>
            <p class="text-center text-[11px] text-fuchsia-400/70 mt-4 font-light">* سەرنج: هەر ئامێرێک لە ڕۆژێکدا تەنها یەک نۆرەی بۆ هەیە.</p>
        </section>
    </main>

    <div id="adminModal" class="fixed inset-0 bg-black/80 backdrop-blur-md hidden items-center justify-center p-4 z-50">
        <div class="neon-card rounded-2xl p-6 w-full max-w-sm shadow-2xl border border-violet-500/20">
            <h3 class="text-xs font-bold text-violet-400 tracking-wider mb-4 uppercase">چوونەژووری ئەدمین</h3>
            <input type="password" id="adminCode" placeholder="••••" class="w-full bg-black/50 border border-white/10 rounded-xl p-3 text-center text-white text-xl tracking-widest mb-4 focus:outline-none focus:border-violet-500">
            <div class="flex gap-2">
                <button onclick="verifyAdmin()" class="w-full bg-gradient-to-r from-violet-600 to-fuchsia-600 text-white font-bold p-2.5 rounded-xl text-xs transition hover:opacity-90">چوونەژوورەوە</button>
                <button onclick="closeAdminModal()" class="w-1/2 bg-white/5 text-gray-400 p-2.5 rounded-xl text-xs transition hover:bg-white/10">پاشگەزبوونەوە</button>
            </div>
        </div>
    </div>

    <div id="dashboardModal" class="fixed inset-0 bg-black/80 backdrop-blur-lg hidden overflow-y-auto p-4 z-50">
        <div class="neon-card rounded-2xl max-w-2xl mx-auto mt-12 p-6 shadow-2xl border border-violet-500/20">
            <div class="flex justify-between items-center mb-6 border-b border-white/10 pb-3">
                <h3 class="text-sm font-bold text-violet-400">کۆنتڕۆڵکردنی کاتی کڕیارەکان</h3>
                <button onclick="closeDashboard()" class="text-xs text-gray-400 hover:text-white bg-white/5 px-3 py-1.5 rounded-lg">داخستن</button>
            </div>
            <div id="adminList" class="space-y-2">
                </div>
        </div>
    </div>

    <footer class="p-4 text-center text-[10px] text-gray-600 border-t border-white/5">
        <p>© 2026 GARMYAN STYLE Studio. Crafted with Elegance.</p>
    </footer>

    <script>
        const workingHours = [
            "04:00 PM", "05:00 PM", "06:00 PM", "07:00 PM", 
            "08:00 PM", "09:00 PM", "10:00 PM", "11:00 PM"
        ];

        let appointments = JSON.parse(localStorage.getItem('garmyan_style_slots')) || {};

        function initSlots() {
            const container = document.getElementById('slotsContainer');
            container.innerHTML = '';

            workingHours.forEach(time => {
                const isBooked = appointments[time];
                const btn = document.createElement('button');
                
                btn.className = `p-4 rounded-2xl text-center border transition-all duration-300 flex flex-col items-center justify-center gap-2 ${
                    isBooked 
                    ? 'bg-red-500/5 border-red-500/10 text-red-400/40 cursor-not-allowed line-through' 
                    : 'bg-white/5 hover:bg-violet-600/20 border-white/5 hover:border-violet-500/50 text-gray-200 hover:-translate-y-0.5 shadow-lg'
                }`;
                
                btn.disabled = isBooked ? true : false;
                btn.onclick = () => bookSlot(time);

                btn.innerHTML = `
                    <span class="font-bold text-xs tracking-wider">${time}</span>
                    <span class="text-[9px] px-2.5 py-0.5 rounded-full font-medium ${isBooked ? 'bg-red-500/10 text-red-400' : 'bg-violet-500/10 text-violet-400'}">
                        ${isBooked ? 'گیراوە' : 'مایە'}
                    </span>
                `;
                container.appendChild(btn);
            });
        }

        function bookSlot(time) {
            const name = document.getElementById('customerName').value.trim();
            const phone = document.getElementById('customerPhone').value.trim();

            if (!name || !phone) {
                alert('تکایە ناو و ژمارەی مۆبایلەکەت بنووسە.');
                return;
            }

            // لۆجیکی ڕێگریکردن لە دووبارەبوونەوە
            const hasBookedBefore = Object.values(appointments).some(app => app.phone === phone);
            const localCheck = localStorage.getItem('garmyan_limit_one');

            if (hasBookedBefore || localCheck) {
                alert('سیستەمەکە ڕێگەت پێ نادات! تۆ لەمڕۆدا نۆرەت گرتووە.');
                return;
            }

            appointments[time] = { name, phone };
            localStorage.setItem('garmyan_style_slots', JSON.stringify(appointments));
            localStorage.setItem('garmyan_limit_one', 'true'); 
            
            document.getElementById('customerName').value = '';
            document.getElementById('customerPhone').value = '';
            
            alert(`نۆرەکەت لە کاتژمێر ${time} بە سەرکەوتوویی جێگیرکرا.`);
            initSlots();
        }

        function openAdminModal() { document.getElementById('adminModal').classList.replace('hidden', 'flex'); }
        function closeAdminModal() { document.getElementById('adminModal').classList.replace('flex', 'hidden'); }

        function verifyAdmin() {
            const code = document.getElementById('adminCode').value;
            if (code === '0202') {
                closeAdminModal();
                document.getElementById('adminCode').value = '';
                openDashboard();
            } else {
                alert('کۆدەکە هەڵەیە!');
            }
        }

        function openDashboard() {
            document.getElementById('dashboardModal').classList.remove('hidden');
            const list = document.getElementById('adminList');
            list.innerHTML = '';

            let hasData = false;
            workingHours.forEach(time => {
                if (appointments[time]) {
                    hasData = true;
                    const div = document.createElement('div');
                    div.className = "flex justify-between items-center bg-black/40 p-4 rounded-xl border border-white/5";
                    div.innerHTML = `
                        <div>
                            <p class="text-violet-400 font-bold text-xs">${time}</p>
                            <p class="text-sm text-white font-medium mt-0.5">${appointments[time].name}</p>
                            <p class="text-xs text-gray-500 mt-0.5" dir="ltr">${appointments[time].phone}</p>
                        </div>
                        <button onclick="cancelSlot('${time}')" class="bg-red-500/10 hover:bg-red-600 text-red-400 hover:text-white text-xs px-3 py-1.5 rounded-lg transition-all">
                            سڕینەوە
                        </button>
                    `;
                    list.appendChild(div);
                }
            });

            if (!hasData) {
                list.innerHTML = `<p class="text-gray-600 text-center py-4 text-xs">هیچ نۆرەیەک لێرە نییە.</p>`;
            }
        }

        function cancelSlot(time) {
            if (confirm(`دڵنیای لە سڕینەوەی کاتی کاتژمێر ${time}?`)) {
                delete appointments[time];
                localStorage.setItem('garmyan_style_slots', JSON.stringify(appointments));
                localStorage.removeItem('garmyan_limit_one'); 
                openDashboard();
                initSlots();
            }
        }

        function closeDashboard() { document.getElementById('dashboardModal').classList.add('hidden'); }

        initSlots();
    </script>
</body>
</html>
